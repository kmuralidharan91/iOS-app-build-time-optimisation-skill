{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kmuralidharan91/iOS-app-build-time-optimisation-skill/schemas/simulation.schema.json",
  "title": "ios-build-simulate output",
  "description": "Predicted Δ wall-clock per diagnose rule. Read alongside the diagnosis artifact whose findings drove each prediction. Predictions are per-rule (aggregating multiple same-rule findings), not per-finding, so the simulation surface stays user-actionable. Every prediction carries a tuning_data_point on both clean and incremental axes per AGENTS.md non-negotiable principle 5.",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "generated_at",
    "inputs",
    "predictions",
    "summary",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "const": "ios-build-simulate" },
        "version": { "type": "string" }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "object",
      "required": ["diagnosis_artifact_path"],
      "additionalProperties": false,
      "properties": {
        "diagnosis_artifact_path": { "type": "string" },
        "measurement_artifact_path": { "type": ["string", "null"] },
        "git_sha": { "type": "string" },
        "git_branch": { "type": "string" }
      }
    },
    "predictions": {
      "type": "array",
      "items": { "$ref": "#/$defs/RulePrediction" }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_predicted_clean_seconds",
        "total_predicted_incremental_seconds",
        "top_3_by_clean",
        "top_3_by_incremental"
      ],
      "additionalProperties": false,
      "properties": {
        "total_predicted_clean_seconds": { "type": "number" },
        "total_predicted_incremental_seconds": { "type": "number" },
        "top_3_by_clean": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3
        },
        "top_3_by_incremental": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "Prediction": {
      "type": "object",
      "required": [
        "method",
        "estimate_seconds",
        "min_seconds",
        "max_seconds",
        "tuning_data_point"
      ],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "measured-on-private-corpus",
            "measured-on-wikipedia",
            "heuristic",
            "literature"
          ]
        },
        "estimate_seconds": { "type": ["number", "null"] },
        "min_seconds": { "type": ["number", "null"] },
        "max_seconds": { "type": ["number", "null"] },
        "tuning_data_point": {
          "type": "string",
          "minLength": 1,
          "description": "Required: project + run that motivated this prediction (AGENTS.md principle 5). E.g. 'Step7_RunCrashlytics.sh: sleep $[ ($RANDOM % 10) + 1 ]s -> mean 5.5s'."
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "RulePrediction": {
      "type": "object",
      "required": [
        "rule_id",
        "family",
        "title",
        "source_findings",
        "clean",
        "incremental",
        "confidence",
        "prerequisites",
        "applies_when",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "rule_id": { "type": "string" },
        "family": {
          "type": "string",
          "enum": ["script-phase", "build-setting", "asset-catalog", "spm"]
        },
        "title": { "type": "string" },
        "source_findings": {
          "type": "object",
          "required": ["indices", "count"],
          "additionalProperties": false,
          "description": "Pointers back to the source diagnosis arrays. Non-negative indices point into diagnosis.findings[]; negative indices encode -1 - additional_recommendations[i] (so -1 == additional_recommendations[0], -2 == additional_recommendations[1], etc.). count == len(indices).",
          "properties": {
            "indices": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "count": { "type": "integer", "minimum": 0 }
          }
        },
        "clean": { "$ref": "#/$defs/Prediction" },
        "incremental": { "$ref": "#/$defs/Prediction" },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "prerequisites": {
          "type": "array",
          "items": { "type": "string" }
        },
        "applies_when": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
