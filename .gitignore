# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Local artifacts created by skill scripts (kept per-project, not checked in here)
.build-history/
.build-benchmark/

# Editor
.vscode/
.idea/
*.swp

# Smoke + verification scratch (chat outputs go to docs/smoke/, docs/verification/ — those ARE checked in)
/tmp-scratch/

# Xcode result bundles produced by smoke runs are large binary blobs.
*.xcresult/

# Full xcodebuild stdout per-run logs are large (~40MB each).
docs/smoke/**/runs-*/build-clean-*.log
docs/smoke/**/runs-*/build-incremental-*.log

# Benchmark artifacts: machine-specific runtime outputs containing absolute
# filesystem paths (project_root, result_bundle_path, etc.). Never commit —
# regenerate locally via scripts/benchmark.py instead.
/build-benchmarks/
