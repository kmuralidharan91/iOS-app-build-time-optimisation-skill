{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kmuralidharan91/iOS-app-build-time-optimisation-skill/schemas/diagnosis.schema.json",
  "title": "ios-build-diagnose artifact",
  "description": "Output of scripts/diagnose.py: ranked findings against the F1-F9 ground truth (or any iOS project's diagnose pass), plus additional_recommendations[] for suite value-add (PR-#2 sandboxing + fuse).",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "generated_at",
    "project",
    "configuration",
    "inputs",
    "findings",
    "additional_recommendations",
    "summary",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "const": "ios-build-diagnose"},
        "version": {"type": "string"}
      },
      "additionalProperties": false
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "project": {
      "type": "object",
      "required": ["path", "build_system", "git_sha", "git_branch", "platform"],
      "properties": {
        "path": {"type": "string"},
        "build_system": {"type": "string", "enum": ["xcode", "tuist", "bazel"]},
        "git_sha": {"type": "string"},
        "git_branch": {"type": "string"},
        "platform": {"type": "string", "enum": ["ios"]}
      },
      "additionalProperties": false
    },
    "configuration": {
      "type": "object",
      "required": ["scheme", "configuration", "destination"],
      "properties": {
        "scheme": {"type": ["string", "null"]},
        "configuration": {"type": "string"},
        "destination": {"type": "string"}
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "required": ["measurement_artifact_path"],
      "properties": {
        "measurement_artifact_path": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"}
    },
    "additional_recommendations": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"}
    },
    "summary": {
      "type": "object",
      "required": [
        "total_findings",
        "total_additional_recommendations",
        "by_impact",
        "by_family"
      ],
      "properties": {
        "total_findings": {"type": "integer", "minimum": 0},
        "total_additional_recommendations": {"type": "integer", "minimum": 0},
        "by_impact": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "by_family": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "rule_id",
        "family",
        "title",
        "evidence",
        "impact_category",
        "wall_clock_predicted_seconds",
        "citation",
        "source_method",
        "notes"
      ],
      "properties": {
        "rule_id": {"type": "string"},
        "family": {
          "type": "string",
          "enum": ["script-phase", "build-setting", "asset-catalog", "spm"]
        },
        "title": {"type": "string"},
        "evidence": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["file_line", "setting", "measurement", "filesystem"]
            },
            "path": {"type": "string"},
            "line": {"type": "integer", "minimum": 1},
            "key": {"type": "string"},
            "value": {"type": "string"},
            "configuration": {"type": "string"},
            "raw": {"type": "string"}
          },
          "additionalProperties": false
        },
        "impact_category": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "wall_clock_predicted_seconds": {
          "type": "object",
          "required": ["method"],
          "properties": {
            "method": {
              "type": "string",
              "enum": [
                "measured-on-REDACTED",
                "measured-on-wikipedia",
                "heuristic",
                "literature"
              ]
            },
            "estimate_seconds": {"type": ["number", "null"], "minimum": 0},
            "min_seconds": {"type": ["number", "null"], "minimum": 0},
            "max_seconds": {"type": ["number", "null"], "minimum": 0},
            "notes": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        },
        "citation": {
          "type": "object",
          "required": ["url", "source"],
          "properties": {
            "url": {"type": "string", "format": "uri"},
            "source": {"type": "string"}
          },
          "additionalProperties": false
        },
        "source_method": {
          "type": "string",
          "enum": [
            "pbxproj-parse",
            "showBuildSettings",
            "package-resolved",
            "filesystem-walk",
            "timing-summary"
          ]
        },
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  }
}
